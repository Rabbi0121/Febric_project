# Data lakehouse root (OneLake-mapped path or local path)
DATA_LAKE_ROOT=data/lakehouse

# Weather location defaults
WEATHER_CITY_NAME=New York
WEATHER_LATITUDE=40.7128
WEATHER_LONGITUDE=-74.0060
WEATHER_TIMEZONE=America/New_York

# Weather to time-series sync
WEATHER_SYNC_INTERVAL_MINUTES=30

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=replace_with_real_token
INFLUXDB_ORG=fabric-project
INFLUXDB_BUCKET=weather_timeseries
# Container-only overrides (optional)
GRAFANA_INFLUXDB_URL=http://influxdb:8086
WEATHER_SYNC_INFLUXDB_URL=http://influxdb:8086

# Great Expectations config
QUALITY_CHECKS_CONFIG=config/quality_checks.yaml

# OpenAQ API v3
# Optional if datasets.openaq.required=false in config/datasets.yaml
OPENAQ_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
